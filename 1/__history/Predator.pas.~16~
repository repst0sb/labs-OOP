unit Predator;

interface

uses WildAnimal, Vcl.ExtCtrls;

type
  TPredator = class(TWildAnimal)
  private
    FPrey: string;
  public
    constructor Create(AIndex: integer; AColor: string; ADanger: string;
      APrey: string; AImage: TImage);
    property Prey: string read Prey;
  end;

implementation

constructor TPredator.Create(AIndex: integer; AColor: string; ADanger: String;
  APrey: string; AImage: TImage);
begin
  inherited Create(AIndex, AColor, ADanger, AImage);
  FPrey := APrey;
end;

end.
