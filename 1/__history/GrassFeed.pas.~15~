unit GrassFeed;

interface

uses WildAnimal, Vcl.ExtCtrls;

type
  TGrassFeed = class(TWildAnimal)
  private
    FMainFood: string;
  public
    constructor Create(AIndex: integer; AColor: string; ADanger: string; AMainFood: string;
      AImage: TImage);
  end;

implementation

constructor TGrassFeed.Create(AIndex: integer; AColor: string; ADanger: string;
  AMainFood: string; AImage: TImage);
begin
  inherited Create(AIndex, AColor, ADanger, AImage);
  FMainFood := AMainFood;
end;

end.
