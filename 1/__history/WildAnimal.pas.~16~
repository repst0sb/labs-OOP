unit WildAnimal;

interface

Uses Animal, Vcl.ExtCtrls;

type
  TWildAnimal = class(TAnimal)
  private
    FDanger: integer;
  public
    constructor Create(const AName, AColor: string; ADanger: integer; AImage: TImage);
  end;

implementation

constructor TWildAnimal.Create(const AName, AColor: string; ADanger: integer; AImage: TImage);
begin
  inherited Create(AName, AColor, AImage);
  FDanger := ADanger;
end;

end.
