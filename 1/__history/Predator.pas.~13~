unit Predator;

interface

uses WildAnimal, Vcl.ExtCtrls;

type
  TPredator = class(TWildAnimal)
  private
    FPrey: string;
  public
    constructor Create(AIndex: integer; AColor: string; ADanger: integer; APrey: string;
      AImage: TImage);
  end;

implementation

constructor TPredator.Create(AIndex: integer; AColor: string; ADanger: integer; APrey: string;
  AImage: TImage);
begin
  inherited Create(AIndex, AColor, ADanger, AImage);
  FPrey := APrey;
end;

end.
