unit DomasticAnimal;

interface

Uses Animal, Vcl.ExtCtrls;

type
  TDomasticAnimal = class(TAnimal)
  private
    FNickName: string;
  public
    constructor Create( AColor: string; ANickName: string; AImage: TImage);
  end;

implementation

constructor TDomasticAnimal.Create(AColor: string;
  ANickName: string; AImage: TImage);
begin
  inherited Create( AColor, AImage);
  FNickName := ANickName;
end;

end.
