unit DomasticAnimal;

interface

Uses Animal, Vcl.ExtCtrls;

type
  TDomasticAnimal = class(TAnimal)
  private
    FNickName: string;
  public
    constructor Create(AIndex: integer; AColor: string; ANickName: string;
      AImage: TImage);
    property NickName: string read FNIckName;
  end;

implementation

constructor TDomasticAnimal.Create(AIndex: integer; AColor: string;
  ANickName: string; AImage: TImage);
begin
  inherited Create(AIndex, AColor, AImage);
  FNickName := ANickName;
end;

end.
