unit DomasticAnimal;

interface

Uses Animal;

type
  TDomasticAnimal = class(TAnimal)
  private
    FNickName: string;
  public
    constructor Create(const AName, AColor: string; ANickName: string);
  end;

implementation

constructor TDomasticAnimal.Create(const AName, AColor: string;
  ANickName: string);
begin
  inherited Create(AName, AColor);
  FNickName := ANickName;
end;

end.
