unit WildAnimal;

interface

Uses Animal;

type
  TWildAnimal = class(TAnimal)
  private
    FDanger: integer;
  public
    constructor Create(const AName, AColor: string; ADanger: integer);
  end;

implementation

constructor TWildAnimal.Create(const AName, AColor: string; ADanger: integer);
begin
  inherited Create(AName, AColor);
  FDanger := ADanger;
end;

end.
