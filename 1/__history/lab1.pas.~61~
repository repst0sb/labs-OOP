unit lab1;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants,
  System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Animal, WildAnimal, DomasticAnimal,
  ExoticDomastic,
  Predator, GrassFeed, Vcl.ExtCtrls, Vcl.Imaging.pngimage, Vcl.StdCtrls,
  System.Generics.Collections;

type
  TForm1 = class(TForm)
    procedure btnDeleteClick(Sender: TObject);
  published
    pMainMenu: TPanel;
    pField: TPanel;
    imgBackground: TImage;
    cbType: TComboBox;
    lType: TLabel;
    cbAnimal: TComboBox;
    lAnimal: TLabel;
    lColor: TLabel;
    lDanger: TLabel;
    eNickName: TEdit;
    lNickName: TLabel;
    eDanger: TEdit;
    lPrey: TLabel;
    ePrey: TEdit;
    lMainFood: TLabel;
    eMainFood: TEdit;
    btnAdd: TButton;
    btnDelete: TButton;
    pInf: TPanel;
    cbColor: TComboBox;
    imgAnimal: TImage;
    procedure FormCreate(Sender: TObject);
    procedure cbAnimalChange(Sender: TObject);
    procedure cbTypeChange(Sender: TObject);
    procedure btnAddClick(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure OnClick(Sender: TObject);
  private
    procedure FillEdits(cbType: TComboBox; cbAnimal: TComboBox);

  var
    Animal: TAnimal;
  public

  end;

var
  Form1: TForm1;
  AnimalsList: TObjectList<TAnimal>;
  imgAnimalPath: string;

implementation

{$R *.dfm}

procedure TForm1.OnClick(Sender: TObject);
var
  Found: Boolean;
  curAnimal: TAnimal;
begin
  Animal := nil;
  Found := False;
  if Sender is TImage then
  begin
    btnAdd.Visible := False;
    btnDelete.Visible := True;
    cbType.Enabled := False;
    cbAnimal.Enabled := False;
    cbColor.Enabled := False;
    eNickName.ReadOnly := True;
    for curAnimal in AnimalsList do
    begin
      if curAnimal.img = Sender then
      begin
        Found := True;
        Animal := curAnimal;
        if curAnimal is TDomasticAnimal then
        begin
          cbType.ItemIndex := 0;
          cbTypeChange(cbType);
          cbAnimal.ItemIndex := curAnimal.Ind;
          cbAnimalChange(cbAnimal);
          eNickName.Text := (curAnimal as TDomasticAnimal).NickName;
          cbColor.ItemIndex := curAnimal.Color;
        end
        else
        begin
          cbType.ItemIndex := 1;
          cbTypeChange(cbType);
          cbAnimal.ItemIndex := curAnimal.Ind;
          cbAnimalChange(cbAnimal);
          cbColor.ItemIndex := curAnimal.Color;
        end;
      end;
    end;
  end;
  if not Found then
  begin
    btnAdd.Visible := True;
    btnDelete.Visible := False;
    cbType.Enabled := True;
    cbAnimal.Enabled := True;
    cbColor.Enabled := True;
    eNickName.ReadOnly := False;
  end;

end;

procedure ShowLabelEdit(lName: TLabel; eName: TEdit);
begin
  lName.Visible := True;
  eName.Visible := True;
end;

procedure HideLabelEdit(lName: TLabel; eName: TEdit);
begin
  lName.Visible := False;
  eName.Visible := False;
end;

procedure TForm1.btnAddClick(Sender: TObject);
var
  NewAnimal: TAnimal;
  NewImage: TImage;
begin
  NewImage := TImage.Create(pField);
  NewImage.Parent := pField;
  NewImage.Width := 205;
  NewImage.Height := 205;
  NewImage.Stretch := True;
  NewImage.Top := pField.Height div 2;
  NewImage.Left := pField.Width div 2;
  NewImage.Visible := True;
  NewImage.Picture.LoadFromFile(imgAnimalPath);
  NewImage.OnClick := OnClick;
  if (cbType.ItemIndex = 0) then
  begin
    case cbAnimal.ItemIndex of
      0 .. 1:
        begin
          NewAnimal := TDomasticAnimal.Create(cbAnimal.ItemIndex,
            cbColor.ItemIndex, eNickName.Text, NewImage);
        end;
      2 .. 3:
        begin
          NewAnimal := TExoticAnimal.Create(cbAnimal.ItemIndex,
            cbColor.ItemIndex, eNickName.Text, eDanger.Text, NewImage);
        end;
    end;
  end
  else
  begin
    case cbAnimal.ItemIndex of
      0 .. 1:
        begin
          NewAnimal := TPredator.Create(cbAnimal.ItemIndex, cbColor.ItemIndex,
            eDanger.Text, ePrey.Text, NewImage);
        end;
      2 .. 3:
        begin
          NewAnimal := TGrassFeed.Create(cbAnimal.ItemIndex, cbColor.ItemIndex,
            eDanger.Text, eMainFood.Text, NewImage);
        end;
    end;
  end;
  AnimalsList.Add(NewAnimal);
end;

procedure TForm1.btnDeleteClick(Sender: TObject);
begin
  if Animal <> nil then
  begin
    Animal.img.Free;
    AnimalsList.Remove(Animal);
    Animal := nil;
    btnAdd.Visible := True;
    btnDelete.Visible := False;
  end;
end;

procedure TForm1.cbAnimalChange(Sender: TObject);
begin
  FillEdits(cbType, cbAnimal);
end;

procedure TForm1.cbTypeChange(Sender: TObject);
begin
  if cbType.ItemIndex = 0 then
  begin
    cbAnimal.Items[0] := 'Кот';
    cbAnimal.Items[1] := 'Собака';
    cbAnimal.Items[2] := 'Змея';
    cbAnimal.Items[3] := 'Енот';
  end
  else
  begin
    cbAnimal.Items[0] := 'Волк';
    cbAnimal.Items[1] := 'Лев';
    cbAnimal.Items[2] := 'Олень';
    cbAnimal.Items[3] := 'Заяц';
  end;
  cbAnimal.ItemIndex := 0;
  FillEdits(cbType, cbAnimal);
end;

procedure TForm1.FillEdits(cbType: TComboBox; cbAnimal: TComboBox);
begin
  HideLabelEdit(lNickName, eNickName);
  HideLabelEdit(lDanger, eDanger);
  HideLabelEdit(lPrey, ePrey);
  HideLabelEdit(lMainFood, eMainFood);
  if (cbType.ItemIndex = 0) then
  begin
    case cbAnimal.ItemIndex of
      0:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/cat.png';
          ShowLabelEdit(lNickName, eNickName);
          cbColor.Items[0] := 'Черный';
          cbColor.Items[1] := 'Белый';
          cbColor.Items[2] := 'Рыжий';
          cbColor.ItemIndex := 0;
          eNickName.Text := 'Вася';
        end;
      1:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/dog.png';
          ShowLabelEdit(lNickName, eNickName);
          cbColor.ItemIndex := 0;
          eNickName.Text := 'Тузик';
        end;
      2:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/snake.png';
          ShowLabelEdit(lNickName, eNickName);
          ShowLabelEdit(lDanger, eDanger);
          cbColor.Items[0] := 'Зеленый';
          cbColor.Items[1] := 'Черный';
          cbColor.Items.Delete(2);
          cbColor.ItemIndex := 0;
          eNickName.Text := 'Лия';
          eDanger.Text := '3';
        end;
      3:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) +
            '../../img/racoon.png';
          ShowLabelEdit(lNickName, eNickName);
          ShowLabelEdit(lDanger, eDanger);
          cbColor.Items[0] := 'Белый';
          cbColor.Items[1] := 'Серый';
          cbColor.Items.Delete(2);
          cbColor.ItemIndex := 0;
          eNickName.Text := 'Толик';
          eDanger.Text := '3';
        end;
    end;
  end
  else
  begin
    case cbAnimal.ItemIndex of
      0:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/wolf.png';
          ShowLabelEdit(lDanger, eDanger);
          ShowLabelEdit(lPrey, ePrey);
          cbColor.Items[0] := 'Черный';
          cbColor.Items[1] := 'Белый';
          cbColor.Items[2] := 'Серый';
          cbColor.ItemIndex := 0;
          eDanger.Text := '5';
          ePrey.Text := 'Зайцы, косули';
        end;
      1:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/lion.png';
          ShowLabelEdit(lDanger, eDanger);
          ShowLabelEdit(lPrey, ePrey);
          cbColor.Items[0] := 'Желтый';
          cbColor.Items[1] := 'Белый';
          cbColor.Items.Delete(2);
          cbColor.ItemIndex := 0;
          eDanger.Text := '5';
          ePrey.Text := 'Зебры, антилопы';
        end;
      2:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/deer.png';
          ShowLabelEdit(lMainFood, eMainFood);
          ShowLabelEdit(lDanger, eDanger);
          cbColor.Items[0] := 'Коричневый';
          cbColor.Items[1] := 'Серый';
          cbColor.Items[2] := 'Белый';
          cbColor.ItemIndex := 0;
          eMainFood.Text := 'Трава, листья';
          eDanger.Text := '4';
        end;
      3:
        begin
          imgAnimalPath := ExtractFilePath(ParamStr(0)) + '../../img/hare.png';
          ShowLabelEdit(lMainFood, eMainFood);
          ShowLabelEdit(lDanger, eDanger);
          cbColor.Items[0] := 'Белый';
          cbColor.Items[1] := 'Серый';
          cbColor.Items[2] := 'Рыжий';
          cbColor.ItemIndex := 0;
          eMainFood.Text := 'Трава, морковка';
          eDanger.Text := '2';
        end;
    end;
  end;
  try
    imgAnimal.Picture.LoadFromFile(imgAnimalPath);
  except
    ShowMessage('Не удалось найти картинку')
  end;

end;

procedure TForm1.FormCreate(Sender: TObject);
begin
  AnimalsList := TObjectList<TAnimal>.Create(True);
  FillEdits(cbType, cbAnimal);
  btnDelete.Visible := False;
end;

procedure TForm1.FormDestroy(Sender: TObject);
begin
  AnimalsList.Free;
end;

end.
