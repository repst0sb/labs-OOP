unit DomasticAnimal;

interface

Uses Animal, Vcl.ExtCtrls;

type
  TDomasticAnimal = class(TAnimal)
  private
    FNickName: string;
  public
    constructor Create(AIndex: integer; AColor: string; ANickName: string; AImage: TImage);
  end;

implementation

constructor TDomasticAnimal.Create(AIndex: integer; AColor: string; ANickName: string;
  AImage: TImage);
begin
  inherited Create(Aindex, AColor, AImage);
  FNickName := ANickName;
end;

end.
