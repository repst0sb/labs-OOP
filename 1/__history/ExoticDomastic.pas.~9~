unit ExoticDomastic;

interface

Uses DomasticAnimal, Vcl.ExtCtrls;

type
  TExoticAnimal = class(TDomasticAnimal)
  private
    FDanger: integer;
  public
    constructor Create(const AName, AColor: string; ANickName: string;
      ADanger: integer; AImage: TImage);
  end;

implementation

constructor TExoticAnimal.Create(const AName, AColor: string; ANickName: string;
  ADanger: integer; AImage: TImage);
begin
  inherited Create(AName, AColor, ANickName, AImage);
  FDanger := ADanger;
end;

end.
